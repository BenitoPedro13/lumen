# Neon connection string (provisioned via `vercel integration add neon`)
DATABASE_URL=

# Anthropic API key (console.anthropic.com — a Claude.ai Pro/Max subscription
# does NOT grant this; API access is billed separately). Calls go straight to
# Anthropic via @ai-sdk/anthropic — not routed through Vercel AI Gateway.
ANTHROPIC_API_KEY=

# Admin secret for provisioning new users via POST /api/admin/users.
# Treat this like a password — anyone with this token can create accounts.
# Set this as a Vercel project env var (not here) for production.
# Any long random string works locally if you want to curl the endpoint yourself.
ADMIN_SECRET=

# Set this as a Vercel project env var (not here) and Vercel Cron will automatically
# send it as `Authorization: Bearer $CRON_SECRET` when it invokes /api/recap/run and
# /api/recap/daily — no code-side wiring needed beyond reading it.
# Any long random string works locally if you want to curl the routes yourself.
CRON_SECRET=
