# Neon connection string (provisioned via `vercel integration add neon`)
DATABASE_URL=

# Shared bearer token both Shortcuts send in the Authorization header
LUMEN_API_TOKEN=

# Anthropic API key (console.anthropic.com — a Claude.ai Pro/Max subscription
# does NOT grant this; API access is billed separately). Calls go straight to
# Anthropic via @ai-sdk/anthropic — not routed through Vercel AI Gateway.
ANTHROPIC_API_KEY=

# Set this as a Vercel project env var (not here) and Vercel Cron will automatically
# send it as `Authorization: Bearer $CRON_SECRET` when it invokes /api/recap/run —
# no code-side wiring needed beyond reading it. Any long random string works locally
# if you want to curl the route yourself.
CRON_SECRET=

# ntfy.sh topic the weekly recap gets pushed to (subscribe to it in the ntfy iOS app —
# treat the topic name like a password, anyone who knows it can read the pushes).
NTFY_TOPIC=
