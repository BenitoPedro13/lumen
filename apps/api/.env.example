# Neon connection string (provisioned via `vercel integration add neon`)
DATABASE_URL=

# Shared bearer token both Shortcuts send in the Authorization header
LUMEN_API_TOKEN=

# Anthropic API key (console.anthropic.com — a Claude.ai Pro/Max subscription
# does NOT grant this; API access is billed separately). Calls go straight to
# Anthropic via @ai-sdk/anthropic — not routed through Vercel AI Gateway.
ANTHROPIC_API_KEY=
